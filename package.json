{
  "name": "achatx",
  "description": "AchatX desktop chat client",
  "author": "AchatX",
  "license": "GPL-3.0-only",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "main": "apps/main/main.cjs",
  "scripts": {
    "dev": "vite",
    "proxy:llm": "node apps/server/llm-proxy.mjs",
    "dev:all": "concurrently -k -n proxy,dev -c yellow,cyan \"npm run proxy:llm\" \"npm run dev\"",
    "electron:dev": "concurrently -k -n dev,electron -c cyan,magenta \"npm run dev\" \"wait-on http://localhost:3000 && set VITE_DEV_SERVER_URL=http://localhost:3000 && electron .\"",
    "build": "vite build",
    "electron:build:win": "npm run build && set \"ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/\" && set \"ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/\" && set \"ELECTRON_CACHE=.cache\\electron\" && set \"ELECTRON_BUILDER_CACHE=.cache\\electron-builder\" && electron-builder --win --x64",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/http-proxy": "^11.4.1",
    "@fastify/reply-from": "^12.6.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@google/genai": "^1.44.0",
    "fastify": "^5.8.1",
    "lucide-react": "^0.577.0",
    "openai": "^6.25.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.achatx.app",
    "productName": "AchatX",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "apps/main/**",
      "apps/shared/**",
      "assets/icons/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "apps/server",
        "to": "server"
      },
      {
        "from": "apps/shared",
        "to": "shared"
      }
    ],
    "win": {
      "executableName": "AchatX",
      "icon": "assets/icons/app.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "assets/icons/app.ico",
      "uninstallerIcon": "assets/icons/app.ico",
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "XELZSSS",
        "repo": "AchatX"
      }
    ]
  }
}
